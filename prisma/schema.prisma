generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  username       String?          @unique
  passwordHash   String
  name           String?
  role           String           @default("user")
  discountCouponClaimed   Boolean @default(false)
  discountCouponClaimedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  membership     Membership?
  files          UploadedFile[]
  usages         UsageRecord[]
  aiChatSessions AiChatSession[]
  upgradeOrders  UpgradeOrder[]
  supportConversations SupportConversation[]
}

model Membership {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           String    @default("free") // 枚举: free, startup, pro
  status         String    @default("trial") // 枚举: trial, active, expired, cancelled
  trialRemaining Int       @default(10)
  startAt        DateTime  @default(now())
  expireAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UploadedFile {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  mimeType     String
  size         Int
  
  blobUrl      String   // Vercel Blob 的访问 URL
  blobPathname String   // Vercel Blob 的全局唯一 key

  createdAt    DateTime @default(now())
}

model UsageRecord {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureType  String
  fileId       String?
  requestCount Int      @default(1)
  createdAt    DateTime @default(now())
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String          @default("New Chat")
  topic     String?
  messages  AiChatMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AiChatMessage {
  id               String        @id @default(uuid())
  sessionId        String
  session          AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             String        // "user" | "model"
  content          String        @db.Text
  attachmentFileId String?
  createdAt        DateTime      @default(now())
}

model UpgradeOrder {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          String
  amount        Float
  currency      String
  referenceCode String    @unique
  paymentMethod String?
  status        String    @default("pending_payment")
  payerOrderNo       String?
  proofImageUrl      String?
  proofImagePathname String?
  couponApplied      Boolean   @default(false)
  originalAmount     Float?
  discountAmount     Float?
  abandonedAt        DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewedAt    DateTime?
}

model SupportConversation {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String           @default("Support Request")
  status        String           @default("open")
  messages      SupportMessage[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lastMessageAt DateTime         @default(now())
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderRole     String              // "user" | "admin"
  senderUserId   String?
  content        String              @db.Text
  isRead         Boolean             @default(false)
  createdAt      DateTime            @default(now())
}

model ComplianceSource {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("official") // official | news | industry | manual
  country     String   @default("Malaysia")
  url         String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles    ComplianceArticle[]
}

model ComplianceArticle {
  id            String   @id @default(uuid())
  sourceId      String?
  source        ComplianceSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  title         String
  summary       String?  @db.Text
  content       String?  @db.Text
  url           String
  urlHash       String   @unique
  country       String   @default("Malaysia")
  category      String?  // policy | customs | trademark | platform | tax | logistics | ecommerce | company
  language      String?  // zh | en | ms
  publishedAt   DateTime?
  crawledAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  status        String   @default("draft") // draft | reviewed | published | rejected
  relevance     Int?     // 0-100
  tags          String[] @default([])

  @@index([country])
  @@index([category])
  @@index([publishedAt])
  @@index([status])
}

model ComplianceCrawlRun {
  id          String   @id @default(uuid())
  sourceName  String
  status      String   // success | partial | failed
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  foundCount   Int      @default(0)
  savedCount   Int      @default(0)
  errorMessage String?  @db.Text
}
