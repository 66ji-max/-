generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  username       String?          @unique
  passwordHash   String
  name           String?
  role           String           @default("user")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  membership     Membership?
  files          UploadedFile[]
  usages         UsageRecord[]
  aiChatSessions AiChatSession[]
}

model Membership {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           String    @default("free") // 枚举: free, startup, pro
  status         String    @default("trial") // 枚举: trial, active, expired, cancelled
  trialRemaining Int       @default(10)
  startAt        DateTime  @default(now())
  expireAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UploadedFile {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  mimeType     String
  size         Int
  
  blobUrl      String   // Vercel Blob 的访问 URL
  blobPathname String   // Vercel Blob 的全局唯一 key

  createdAt    DateTime @default(now())
}

model UsageRecord {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureType  String
  fileId       String?
  requestCount Int      @default(1)
  createdAt    DateTime @default(now())
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String          @default("New Chat")
  topic     String?
  messages  AiChatMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AiChatMessage {
  id               String        @id @default(uuid())
  sessionId        String
  session          AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             String        // "user" | "model"
  content          String        @db.Text
  attachmentFileId String?
  createdAt        DateTime      @default(now())
}
