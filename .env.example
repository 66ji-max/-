# Neon Postgres / Vercel Postgres Configuration
POSTGRES_PRISMA_URL="postgresql://neondb_owner:xxxxx@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://neondb_owner:xxxxx@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Vercel Blob 在项目中配置完成后提供的读写凭证
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_*******"

# 安全自签证密钥（请务必在生成环境替换为一个复杂的乱码）
JWT_SECRET="supers3cret_changeme_in_production"

# Preferred: OpenAI-compatible LLM provider
SAILGUARD_LLM_API_KEY=
SAILGUARD_LLM_BASE_URL=https://max.openai365.top/v1
SAILGUARD_LLM_MODEL=gemini-3.1-pro-preview
SAILGUARD_LLM_FALLBACK_MODELS=gemini-3-flash-preview

# Also supported for compatibility
LLM_API_KEY=
LLM_BASE_URL=https://max.openai365.top/v1
LLM_MODEL=gemini-3.1-pro-preview
LLM_FALLBACK_MODEL=gemini-3-flash-preview

# Gemini official fallback
GEMINI_API_KEY="AIzaSyA..."
GOOGLE_AI_API_KEY=
API_KEY=

# Admin Portal Configuration (Seed script credentials, please change in production)
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="supersecretpassword"
