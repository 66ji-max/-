# Neon Postgres 配置
DATABASE_URL="postgresql://neondb_owner:xxxxx@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:xxxxx@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Vercel Blob 在项目中配置完成后提供的读写凭证
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_*******"

# 安全自签证密钥（请务必在生成环境替换为一个复杂的乱码）
JWT_SECRET="supers3cret_changeme_in_production"

# 不向前端暴露的后端大模型服务唯一鉴权
GEMINI_API_KEY="AIzaSyA..."
